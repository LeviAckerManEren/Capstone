import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D
from pathlib import Path

# Output folder
out_dir = Path("outputs")
out_dir.mkdir(exist_ok=True)

# -------------------------
# Data: toy RGB-point-cloud correspondence example
# -------------------------
# Central anchor from RGB modality
anchor = np.array([0.0, 0.0, -2.0])

# Candidate point-cloud nodes
points = np.array([
    [-3.0,  1.5,  2.0],
    [-2.5, -2.0, -3.0],
    [ 1.0,  2.2,  2.5],
    [ 4.0,  1.0,  0.5],
    [ 0.5, -4.5, -8.0],
    [ 2.0, -1.0,  2.8]
])

# -------------------------
# Plot
# -------------------------
fig = plt.figure(figsize=(7, 6))
ax = fig.add_subplot(111, projection="3d")

# Plot point-cloud nodes
ax.scatter(
    points[:, 0], points[:, 1], points[:, 2],
    s=70,
    marker="o",
    facecolors="none",
    label="Point-cloud nodes"
)

# Plot RGB anchor
ax.scatter(
    anchor[0], anchor[1], anchor[2],
    s=70,
    marker="s",
    facecolors="none",
    label="RGB anchor"
)

# Draw correspondence links
for p in points:
    ax.plot(
        [anchor[0], p[0]],
        [anchor[1], p[1]],
        [anchor[2], p[2]],
        linestyle="--",
        linewidth=1
    )

ax.set_xlabel("x (m)")
ax.set_ylabel("y (m)")
ax.set_zlabel("z (m)")
ax.set_title("3D Spatial Correspondence for RGB-Point-Cloud Exploration")

ax.set_xlim(-10, 10)
ax.set_ylim(-10, 10)
ax.set_zlim(-10, 10)

ax.legend()

plt.tight_layout()

save_path = out_dir / "rgb_pointcloud_correspondence.png"
plt.savefig(save_path, dpi=300, bbox_inches="tight")
plt.show()

