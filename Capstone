import matplotlib.pyplot as plt
import networkx as nx
from matplotlib.patches import Ellipse
from pathlib import Path

out_dir = Path("outputs")
out_dir.mkdir(exist_ok=True)

fig, axes = plt.subplots(1, 2, figsize=(12, 5))

# -------------------------
# Left: Scene Graph
# -------------------------
G = nx.DiGraph()
nodes = ["child", "ball", "field", "red", "play"]
G.add_nodes_from(nodes)
G.add_edges_from([
    ("child", "play"),
    ("ball", "play"),
    ("field", "play"),
    ("ball", "red")
])

pos = {
    "child": (0.1, 0.6),
    "ball": (0.4, 0.6),
    "field": (0.7, 0.6),
    "red": (0.4, 0.25),
    "play": (0.4, 0.9)
}

ax = axes[0]
nx.draw_networkx_nodes(G, pos, ax=ax, node_size=1800)
nx.draw_networkx_labels(G, pos, ax=ax, font_size=10)
nx.draw_networkx_edges(G, pos, ax=ax, arrows=True, arrowstyle="->", arrowsize=15)
ax.set_title("(a) Conventional Scene Graph")
ax.axis("off")

# -------------------------
# Right: Hypergraph
# -------------------------
ax = axes[1]
hyper_pos = {
    "child": (0.15, 0.6),
    "ball": (0.45, 0.6),
    "field": (0.75, 0.6),
    "red": (0.45, 0.25),
    "play": (0.45, 0.9)
}

for node, (x, y) in hyper_pos.items():
    ax.scatter(x, y, s=1200)
    ax.text(x, y, node, ha="center", va="center", fontsize=10)

ellipse1 = Ellipse((0.45, 0.68), width=0.75, height=0.45, fill=False, linewidth=2)
ellipse2 = Ellipse((0.45, 0.42), width=0.28, height=0.42, fill=False, linewidth=2)

ax.add_patch(ellipse1)
ax.add_patch(ellipse2)

ax.text(0.82, 0.85, "Hyperedge 1:\nEvent-level group", fontsize=9)
ax.text(0.62, 0.12, "Hyperedge 2:\nAttribute group", fontsize=9)

ax.set_title("(b) Event-level Hypergraph")
ax.set_xlim(0, 1)
ax.set_ylim(0, 1)
ax.axis("off")

fig.suptitle("From Conventional Scene Graph to Event-level Hypergraph", fontsize=14)
plt.tight_layout(rect=[0, 0, 1, 0.93])
plt.savefig(out_dir / "fig_3_1_scenegraph_to_hypergraph.png", dpi=300, bbox_inches="tight")
plt.show()

