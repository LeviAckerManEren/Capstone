# model.py

import torch
import torch.nn as nn

class HypergraphEncoder(nn.Module):
    def __init__(self, dim):
        super().__init__()
        self.W_h = nn.Linear(dim, dim)
        self.W_g = nn.Linear(dim, dim)
        self.W_z = nn.Linear(dim, dim)

        self.w_a = nn.Parameter(torch.randn(dim))
        self.b_a = nn.Parameter(torch.zeros(dim))

    def forward(self, x):
        # x: node features [N, D]
        h = self.W_h(x)
        g = self.W_g(x)

        z = torch.tanh(h + g + self.b_a)
        return self.W_z(z)
